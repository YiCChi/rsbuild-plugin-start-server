{
  "name": "rsbuild-plugin-start-server",
  "version": "0.1.0",
  "type": "module",
  "description": "Automatically (re)start your server once Rsbuild's build completes.",
  "engines": {
    "node": ">=18.12.0"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "dev": "rslib build --watch",
    "build": "rslib build",
    "example:dev": "rsbuild build --watch --env-mode development",
    "example:build:integration": "rsbuild build --env-mode integration",
    "example:build:staging": "rsbuild build --env-mode staging",
    "example:build:production": "rsbuild build --env-mode production"
  },
  "keywords": [
    "rsbuild",
    "plugin",
    "watch",
    "restart",
    "node"
  ],
  "author": "YiCChi",
  "license": "MIT",
  "peerDependencies": {
    "@rsbuild/core": "^1.5.0"
  },
  "devDependencies": {
    "@rsbuild/core": "1.5.4",
    "@rslib/core": "0.12.4",
    "@types/express": "5.0.3",
    "@types/node": "24.3.1",
    "express": "5.1.0",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@10.15.0"
}
